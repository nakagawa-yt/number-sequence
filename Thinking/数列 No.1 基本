<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>のんびり数あそび - スカイパズル</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

    <style>
        :root {
            --sky-blue: #87ceeb;
            --cloud-white: #ffffff;
            --text-color: #4a6670;
            --accent-green: #9edb8a;
            --btn-orange: #ffb347;
            --hint-yellow: #fff380;
        }

        body {
            font-family: 'Hiragino Maru Gothic ProN', 'Meiryo', sans-serif;
            background: linear-gradient(180deg, #b3e5fc 0%, #e1f5fe 100%);
            color: var(--text-color);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: flex-start; /* Chromebookの高さに合わせて上寄せ */
            min-height: 100vh;
            overflow-y: auto; /* 全体スクロールを許可 */
            position: relative;
            padding: 20px 0;
        }

        /* 雲のアニメーション背景 */
        .cloud {
            position: fixed; /* スクロールしても位置を固定 */
            background: white;
            border-radius: 50px;
            opacity: 0.6;
            z-index: -1;
            animation: float 25s linear infinite;
        }
        .cloud::after, .cloud::before {
            content: '';
            position: absolute;
            background: white;
            border-radius: 50%;
        }
        .cloud:nth-child(1) { width: 100px; height: 40px; top: 10%; left: -100px; }
        .cloud:nth-child(2) { width: 150px; height: 60px; top: 30%; left: -150px; animation-duration: 35s; }
        .cloud:nth-child(3) { width: 120px; height: 50px; top: 70%; left: -120px; animation-duration: 30s; }

        @keyframes float {
            from { transform: translateX(-100px); }
            to { transform: translateX(calc(100vw + 200px)); }
        }

        .container {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            width: 90%;
            max-width: 500px;
            padding: 30px 20px;
            border-radius: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
            border: 6px solid white;
            position: relative;
            margin: auto; /* 中央配置 */
        }

        .progress { font-size: 1rem; margin-bottom: 8px; color: #88a; font-weight: bold; }
        h2 { font-size: 1.2rem; margin-bottom: 20px; font-weight: normal; line-height: 1.4; }

        .sequence-box {
            background: rgba(255, 255, 255, 0.5);
            padding: 20px 15px;
            border-radius: 25px;
            min-height: 70px;
            margin-bottom: 25px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            border: 2px solid #e1f5fe;
            font-size: 1.4rem;
            color: #2c3e50;
            flex-wrap: wrap; /* 画面が狭い時に折り返す */
        }

        .input-group {
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 90px;
        }

        input {
            padding: 10px;
            border: 3px solid #eee;
            border-radius: 15px;
            font-size: 1.2rem;
            text-align: center;
            width: 90px;
            outline: none;
            transition: all 0.3s;
            color: var(--text-color);
        }
        input:focus { border-color: var(--btn-orange); transform: scale(1.02); }

        .fraction-input { display: flex; flex-direction: column; align-items: center; gap: 5px; }
        .fraction-line { width: 60px; height: 3px; background-color: var(--text-color); border-radius: 2px; }

        .main-btn {
            background-color: var(--btn-orange);
            color: white;
            border: none;
            padding: 14px 50px;
            border-radius: 35px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 5px 0 #e67e22;
            transition: 0.2s;
            width: 80%; /* 押しやすいサイズに */
        }
        .main-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #e67e22; }

        /* ヒントボタン */
        .hint-container { margin-top: 20px; }
        .hint-btn {
            background-color: #f0f4f8;
            color: #95a5a6;
            border: 2px solid #e1e8ed;
            padding: 8px 20px;
            border-radius: 18px;
            font-size: 0.85rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .hint-content {
            display: none;
            margin-top: 15px;
            padding: 15px;
            background: #fffbe6;
            border-radius: 18px;
            font-size: 0.85rem;
            line-height: 1.5;
            border-left: 5px solid #f1c40f;
            text-align: left;
        }

        .feedback { min-height: 35px; margin-top: 10px; font-weight: bold; font-size: 1.1rem; }

        /* 結果画面とフォームの調整 */
        .form-container {
            margin-top: 20px;
            width: 100%;
            background: white;
            border-radius: 15px;
            overflow: hidden;
            border: 2px solid #e1f5fe;
            -webkit-overflow-scrolling: touch; /* タッチ操作を滑らかに */
        }
        
        iframe {
            width: 100%;
            height: 500px; /* Chromebookでスクロールしやすい高さ */
            border: none;
        }

        #result-view {
            display: none;
            flex-direction: column;
            align-items: center;
        }
    </style>
</head>
<body>

<div class="cloud"></div>
<div class="cloud"></div>
<div class="cloud"></div>

<div class="container">
    <div id="game-view">
        <div class="progress">Step <span id="q-num">1</span> / 5</div>
        <h2 id="q-text">□ にあてはまる数字はなにかな？</h2>
        
        <div id="sequence" class="sequence-box"></div>

        <div id="input-area" class="input-group"></div>

        <button class="main-btn" id="action-btn" onclick="handleAction()">こたえる</button>
        
        <div id="feedback" class="feedback"></div>

        <div class="hint-container">
            <button class="hint-btn" onclick="toggleHint()">
                <span>💡</span> ヒントをみる
            </button>
            <div id="hint-content" class="hint-content"></div>
        </div>
    </div>

    <div id="result-view">
        <div style="font-size: 4rem; margin-bottom: 10px;">🏆</div>
        <h2>全問クリア！<br>法則は見つけられた？</h2>
        
        <p style="font-size: 0.9rem; color: #7f8c8d; margin-bottom: 5px;">まとめ ☁️</p>
        
        <div class="form-container">
            <iframe 
                src="https://forms.gle/zqn7Q6htUM6SKCbZ8" 
                frameborder="0" 
                marginheight="0" 
                marginwidth="0">
                読み込んでいます…
            </iframe>
        </div>

        <button class="main-btn" style="margin-top: 25px;" onclick="location.reload()">もう一度あそぶ</button>
    </div>
</div>

<script>
    const questions = [
        { 
            seq: ["12", "19", "26", "\\square", "40"], 
            ans: "33", 
            hint: "隣り合う数字が「どれくらい離れているか」を考えてみよう。" 
        },
        { 
            type: "fraction", 
            seq: ["\\frac{1}{2}", "\\frac{3}{4}", "1", "\\square", "\\frac{3}{2}"], 
            ans: { bunza: "5", bunbo: "4" }, 
            hint: "整数「1」を分数に書き換えて、すべての分母を「4」にそろえて並べてみよう。"
        },
        { 
            seq: ["2", "-6", "18", "\\square", "162"], 
            ans: "-54", 
            hint: "「＋」と「ー」が交互に入れ替わっていることに注目してみて。何を掛け続けているかな？"
        },
        { 
            seq: ["1", "4", "9", "16", "\\square", "36"], 
            ans: "25", 
            hint: "増えている量自体を書き出してみて。その「増えた量」たちが、さらにどんな規則で増えているか探してみよう。" 
        },
        { 
            seq: ["1", "1", "2", "3", "5", "8", "\\square", "21"], 
            ans: "13", 
            hint: "今の数字は、その「手前にある2つの数字」と深い関係があるみたいだよ。足してみよう。" 
        }
    ];

    let currentIdx = 0;
    let isCorrected = false;

    function toHalfWidth(str) {
        return str.replace(/[！-～]/g, s => String.fromCharCode(s.charCodeAt(0) - 0xFEE0));
    }

    function initQuestion() {
        const q = questions[currentIdx];
        document.getElementById("q-num").innerText = currentIdx + 1;
        document.getElementById("feedback").innerText = "";
        document.getElementById("hint-content").style.display = "none";
        document.getElementById("hint-content").innerText = q.hint;
        document.getElementById("action-btn").innerText = "こたえる";
        isCorrected = false;

        const seqDiv = document.getElementById("sequence");
        seqDiv.innerHTML = "";
        q.seq.forEach((item, index) => {
            const span = document.createElement("span");
            katex.render(item, span);
            seqDiv.appendChild(span);
            if (index < q.seq.length - 1) {
                const comma = document.createElement("span");
                comma.innerText = ",";
                comma.style.marginRight = "10px";
                seqDiv.appendChild(comma);
            }
        });

        const inputArea = document.getElementById("input-area");
        inputArea.innerHTML = "";
        if (q.type === "fraction") {
            inputArea.innerHTML = `
                <div class="fraction-input">
                    <input type="text" id="ans-top" placeholder="分子" autocomplete="off">
                    <div class="fraction-line"></div>
                    <input type="text" id="ans-bottom" placeholder="分母" autocomplete="off">
                </div>`;
        } else {
            inputArea.innerHTML = `<input type="text" id="ans-single" placeholder="？" autocomplete="off">`;
        }
    }

    function handleAction() {
        if (!isCorrected) {
            checkAnswer();
        } else {
            nextQuestion();
        }
    }

    function checkAnswer() {
        const q = questions[currentIdx];
        let userIsCorrect = false;

        if (q.type === "fraction") {
            const top = toHalfWidth(document.getElementById("ans-top").value.trim());
            const bottom = toHalfWidth(document.getElementById("ans-bottom").value.trim());
            if (top === q.ans.bunza && bottom === q.ans.bunbo) userIsCorrect = true;
        } else {
            const val = toHalfWidth(document.getElementById("ans-single").value.trim());
            if (val === q.ans) userIsCorrect = true;
        }

        const fb = document.getElementById("feedback");
        if (userIsCorrect) {
            fb.innerText = "素晴らしい！正解です ✨";
            fb.style.color = "#27ae60";
            document.getElementById("action-btn").innerText = "次の問題へ";
            isCorrected = true;
        } else {
            fb.innerText = "おや、もう一息かな…？";
            fb.style.color = "#e67e22";
        }
    }

    function nextQuestion() {
        currentIdx++;
        if (currentIdx < questions.length) {
            initQuestion();
            window.scrollTo(0,0); // 次の問題で上に戻る
        } else {
            document.getElementById("game-view").style.display = "none";
            document.getElementById("result-view").style.display = "flex";
            window.scrollTo(0,0); // 結果画面で上に戻る
        }
    }

    function toggleHint() {
        const hint = document.getElementById("hint-content");
        hint.style.display = (hint.style.display === "block") ? "none" : "block";
    }

    initQuestion();
</script>

</body>
</html>
